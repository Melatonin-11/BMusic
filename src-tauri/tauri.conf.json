{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "BiliRandomizer",
  "version": "1.0.5",
  "identifier": "com.bili.randomizer",
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "build": {
    "beforeDevCommand": "npm run dev:frontend",
    "beforeBuildCommand": "npm run build:frontend",
    "devUrl": "http://localhost:3000",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [{
      "title": "BiliRandomizer - B站收藏夹融合随机播放器",
      "transparent": true,
      "decorations": false,
      "shadow": true,
      "width": 1120,
      "height": 780,
      "resizable": true,
      "fullscreen": false,
      "center": true
    }],
    "security": { "csp": null }
  }
}
