{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "BiliRandomizer",
  "version": "1.0.8",
  "identifier": "com.bili.randomizer",
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  },
  "build": {
    "beforeDevCommand": "npm run dev:frontend",
    "beforeBuildCommand": "npm run build:frontend",
    "devUrl": "http://localhost:3000",
    "frontendDist": "../dist"
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEVCRDhBMTA0MjY1N0MyQjUKUldTMXdsY21CS0hZNjdaL2YyTEszbFJwQm1sWWRESmhZOU1qbUxmTTRiUWh3QVErOElXWWVQYncK",
      "endpoints": [
        "https://github.com/Melatonin-11/BMusic/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "app": {
    "windows": [
      {
        "title": "BiliRandomizer - B站收藏夹融合随机播放器",
        "transparent": true,
        "decorations": false,
        "shadow": true,
        "width": 1120,
        "height": 780,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  }
}
